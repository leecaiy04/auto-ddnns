# ========== 路由器 ==========
# 路由器连接配置（iKuai Web API；旧 SSH 路由可将 ROUTER_TYPE 改为 legacy_ssh）
ROUTER_HOST=192.168.9.1
ROUTER_USERNAME=router_query_ro
ROUTER_PASSWORD=your-r...word
ROUTER_TYPE=ikuai
ROUTER_SSL_VERIFY=0

# ========== 阿里云 DDNS ==========
# 阿里云 AccessKey 配置
ALIYUN_AK=your-aliyun-access-key-id
ALIYUN_SK=your-aliyun-access-key-secret
ALIYUN_DOMAIN=leecaiy.shop

# ========== Lucky ==========
# Lucky OpenToken（Lucky 设置页中获取）
LUCKY_OPEN_TOKEN=your-lucky-open-token
# Lucky Web 登录（浏览器调试用）
LUCKY_USERNAME=your-lucky-web-username
LUCKY_PASSWORD=your-lucky-web-password
# Lucky API 地址
LUCKY_API_BASE=http://192.168.9.2:16601/666
LUCKY_HTTPS_PORT=50000
# 备用节点（如有）
LUCKY_BACKUP_API_BASE=
LUCKY_BACKUP_USERNAME=
LUCKY_BACKUP_PASSWORD=

# ========== SunPanel ==========
SUNPANEL_API_BASE=http://192.168.9.2:20001/openapi/v1
SUNPANEL_API_TOKEN=your-sunpanel-token
# SunPanel Web 登录（浏览器调试用）
SUNPANEL_USERNAME=your-sunpanel-web-username
SUNPANEL_PASSWORD=your-sunpanel-web-password
# 备用节点（如有）
SUNPANEL_BACKUP_API_BASE=
SUNPANEL_BACKUP_API_TOKEN=

# ========== Central Hub ==========
# 中枢服务配置（监控界面端口）
HUB_PORT=51000
HUB_HOST=0.0.0.0

# ========== DDNS ==========
# DDNS 脚本路径
DDNS_SCRIPT_PATH=./scripts/aliddns_sync.sh
DDNS_TARGETS_CONFIG=./config/private_ipv6_ddns_targets.json
DDNS_UPDATE_INTERVAL=600
# 可选：仅当确实接入飞书消息中心时再打开
MESSAGE_CENTER_DIR=/home/leecaiy/workspace/feishu-message-center
MESSAGE_CLIENT_PATH=/home/leecaiy/workspace/feishu-message-center/machine_client.py
NOTIFY_MACHINE_ID=debian

# ========== Cloudflare ==========
# Cloudflare API Token（在 dash.cloudflare.com → My Profile → API Tokens 中创建）
CF_API_TOKEN=your-cloudflare-api-token
# Zone ID（在域名概览页右侧 API 区域获取）
CF_ZONE_ID=your-zone-id
# 挂在 Cloudflare 的域名
CF_DOMAIN=example.com

# ========== 日志 ==========
# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
