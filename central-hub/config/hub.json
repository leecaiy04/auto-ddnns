{
  "server": {
    "port": 51000,
    "host": "0.0.0.0",
    "cors": {
      "enabled": true,
      "origin": "*"
    }
  },
  "modules": {
    "coordinator": {
      "enabled": true,
      "schedule": {
        "deviceMonitor": "*/10 * * * *",
        "ddns": "0 * * * *",
        "services": "0 */2 * * *",
        "luckySync": "*/15 * * * *",
        "sunpanelSync": "*/15 * * * *",
        "cloudflareSync": "*/15 * * * *"
      }
    },
    "deviceMonitor": {
      "enabled": true,
      "checkInterval": 600,
      "devices": [
        "2",
        "10",
        "200",
        "201",
        "254"
      ],
      "router": {
        "host": "192.168.9.1",
        "username": "root",
        "password": "${ROUTER_PASSWORD}",
        "timeout": 10000
      }
    },
    "ddns": {
      "enabled": true,
      "luckyDdns": {
        "enabled": true,
        "devices": ["2", "10", "200", "201", "254"],
        "domains": ["leecaiy.shop", "222869.xyz"],
        "intervals": 36,
        "forceInterval": 3600
      }
    },
    "lucky": {
      "enabled": true,
      "apiBase": "http://192.168.9.2:16601/666",
      "httpsPort": 55000,
      "autoSync": true,
      "autoCreateProxy": true
    },
    "sunpanel": {
      "enabled": true,
      "apiBase": "http://192.168.9.2:20001/openapi/v1",
      "autoSync": true,
      "autoCreateGroups": true
    },
    "cloudflare": {
      "enabled": false,
      "zoneId": "${CF_ZONE_ID}",
      "domain": "${CF_DOMAIN}",
      "proxied": true,
      "autoSync": true
    }
  },
  "state": {
    "path": "data/hub-state.json",
    "backupPath": "data/backups/",
    "keepHistory": 10,
    "backupKeepHistory": 1
  },
  "logging": {
    "level": "info",
    "file": "logs/hub.log",
    "maxSize": "10M",
    "maxFiles": 5
  }
}
