{
  "name": "auto-dnns",
  "version": "2.0.0",
  "description": "局域网对外部署自动化工具集",
  "type": "module",
  "scripts": {
    "start": "cd central-hub && node server.mjs",
    "dev": "cd central-hub && node --watch server.mjs",
    "test": "node --test test/*.test.mjs",
    "init": "node scripts/init-setup.mjs",
    "install:deps": "npm install && npm --prefix central-hub install",
    "test:steps": "node scripts/test-functional-steps.mjs all",
    "test:steps:start": "node scripts/test-functional-steps.mjs all --spawn",
    "test:step:health": "node scripts/test-functional-steps.mjs health",
    "test:step:status": "node scripts/test-functional-steps.mjs status",
    "test:step:overview": "node scripts/test-functional-steps.mjs overview",
    "test:step:devices": "node scripts/test-functional-steps.mjs devices",
    "test:step:ddns": "node scripts/test-functional-steps.mjs ddns",
    "test:step:schedule": "node scripts/test-functional-steps.mjs schedule",
    "test:step:services": "node scripts/test-functional-steps.mjs services",
    "test:step:inventory": "node scripts/test-functional-steps.mjs inventory"
  },
  "keywords": [
    "ddns",
    "lucky",
    "sunpanel",
    "automation"
  ],
  "author": "leecaiy",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "node-cron": "^3.0.3",
    "axios": "^1.6.0",
    "ssh2": "^1.15.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
